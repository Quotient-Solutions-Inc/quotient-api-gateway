PORT=8787
NODE_ENV=development

# Upstream Quotient API host, no trailing slash.
QUOTIENT_API_BASE_URL=https://quotient-api.vercel.app

# Shared secret forwarded to quotient-api as x-quotient-gateway-secret.
# Must match quotient-api's QUOTIENT_GATEWAY_SHARED_SECRET.
QUOTIENT_GATEWAY_SHARED_SECRET=
# Service token for internal API<->gateway billing/provisioning calls.
# Must match quotient-api's QUOTIENT_INTERNAL_SERVICE_TOKEN.
QUOTIENT_INTERNAL_SERVICE_TOKEN=

# x402 payments (v2)
X402_FACILITATOR_URL=https://facilitator.0xmeta.ai/v1
# Comma-separated CAIP-2 networks enabled for payment options.
# X402_ENABLED_NETWORKS=eip155:84532
X402_ENABLED_NETWORKS=eip155:8453
# Recipient wallet per enabled network.
X402_PAY_TO_EIP155_8453=
X402_PAY_TO_EIP155_84532=
# payment-identifier extension requirement and response-cache TTL.
X402_PAYMENT_ID_REQUIRED=false
X402_IDEMPOTENCY_TTL_SECONDS=3600

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_PLAN_PRODUCT_METADATA_KEY=catalog
STRIPE_PLAN_PRODUCT_METADATA_VALUE=quotient_api
STRIPE_PLAN_CREDITS_METADATA_KEY=included_credits
STRIPE_PLAN_CACHE_TTL_SECONDS=300

# Neo4j billing state (required)
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
