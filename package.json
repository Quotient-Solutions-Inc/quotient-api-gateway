{
  "name": "quotient-api-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "x402-style monetization gateway for Quotient API access.",
  "dependencies": {
    "neo4j-driver": "^5.28.1",
    "stripe": "^18.4.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
