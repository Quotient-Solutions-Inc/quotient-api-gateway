PORT=8787
NODE_ENV=development

# Upstream Quotient API host, no trailing slash.
QUOTIENT_API_BASE_URL=https://quotient-markets-api.onrender.com

# Existing Quotient API key from the Quotient API portal.
QUOTIENT_API_KEY=qt_replace_me
# Shared secret forwarded to quotient-api as x-quotient-gateway-secret.
QUOTIENT_GATEWAY_SHARED_SECRET=

# Mock x402 local settings (Phase 1)
X402_ACCEPTED_CHAIN=base
X402_ACCEPTED_ASSET=USDC
X402_PRICE_MARKETS=0.01
X402_PRICE_INTELLIGENCE=0.02
X402_PRICE_SIGNALS=0.015
X402_TEST_TOKEN=pay_local_test_token

# Subscription billing + credit metering
BILLING_ENABLED=true
BILLING_PROVIDER_MODE=mock
BILLING_PLAN_ID=starter_10
BILLING_PLAN_PRICE_USD=10
BILLING_INCLUDED_CREDITS=1000
BILLING_CREDIT_COST_MARKETS=1
BILLING_CREDIT_COST_INTELLIGENCE=2
BILLING_CREDIT_COST_SIGNALS=2
BILLING_STORE_BACKEND=memory

# Comma-separated SHA256 hashes of API keys treated as active subscribers in mock mode.
BILLING_MOCK_ACTIVE_API_KEY_HASHES=
# Comma-separated canonical User.id values treated as active subscribers in mock mode.
BILLING_MOCK_ACTIVE_USER_IDS=

# Stripe mode (set BILLING_PROVIDER_MODE=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Durable billing state (required when BILLING_STORE_BACKEND=neo4j)
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
